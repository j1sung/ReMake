--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ab19687c99f4ca34e8610fbfa91a6e88, type: 3}
  m_Name: IntroInterview
  m_EditorClassIdentifier: 
  lines:
  - speaker: 0
    text: "\uC6B4\uC774 \uC88B\uB124\uC694. \uB9C8\uCE68 \uC77C\uC190\uC774 \uBD80\uC871\uD558\uB358
      \uCC38\uC774\uB77C."
  - speaker: 0
    text: "\uCD08\uAE30 \uD63C\uB780\uC73C\uB85C \uC778\uD55C \uAE30\uBB3C\uD30C\uC190\uC740
      \n\uADFC\uBB34 \uD0DC\uB3C4\uC5D0 \uB530\uB77C \uAC10\uBA74 \uCC98\uB9AC \uB420
      \uAC81\uB2C8\uB2E4."
  - speaker: 0
    text: "\uB2E4\uB4E4 \uCC98\uC74C\uC5D4 \uC5EC\uAE30\uAC00 \uC5B4\uB518\uC9C0
      \uBAA8\uB978 \uCC44 \uC624\uB2C8\uAE4C\uC694."
  - speaker: 1
    text: "\uC804..."
  - speaker: 1
    text: "\uC8FD\uC740 \uAE30\uC5B5\uC774 \uC5C6\uB294\uB370\uC694."
  - speaker: 0
    text: "\uCC98\uC74C\uC5D4 \uB2E4\uB4E4 \uADF8\uB798\uC694.\n\uC2E4\uAC10\uC774
      \uC798 \uC548 \uB098\uC8E0."
  - speaker: 0
    text: "\uB108\uBB34 \uC0C1\uC2EC\uD558\uC9C4 \uB9D0\uC544\uC694."
  - speaker: 0
    text: "\uAE30\uC5B5\uC744 \uCC3E\uACE0 \uB2E4\uC74C \uC0DD\uC73C\uB85C \uB118\uC5B4\uAC00\uB294
      \uBD84\uB4E4\uB3C4 \uB9CE\uAC70\uB4E0\uC694."
  - speaker: 1
    text: "\uD639\uC2DC \uC77C\uD558\uB2E4 \uBCF4\uBA74 \uAE30\uC5B5\uC774 \uB3CC\uC544\uC624\uB294
      \uAC74\uAC00\uC694?"
  - speaker: 0
    text: "\uB298 \uADF8\uB7F0 \uAC74 \uC544\uB2C8\uC9C0\uB9CC, \uC6B0\uB9AC \uC77C\uC740
      \uAE30\uC5B5\uACFC \uC5BD\uD600 \uC788\uB2E4 \uBCF4\uB2C8\uAE4C\uC694."
  - speaker: 0
    text: "\uC815\uB9AC\uB294 \uC798 \uD574\uC694?"
  - speaker: 1
    text: "...\uC798 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4."
  - speaker: 0
    text: "\uAD1C\uCC2E\uC544\uC694. \uD558\uB2E4 \uBCF4\uBA74 \uB298\uACA0\uC9C0."
  - speaker: 0
    text: "\uC77C\uB2E8 \uB530\uB77C\uC640\uC694. \uC0AC\uC6D0\uC99D \uC798 \uCC59\uAE30\uC2DC\uACE0."
